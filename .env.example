# Copy to .env for local Compose use. .env is ignored by Git.
# Never place CrowdSec machine credentials here; mount the dedicated YAML file.
CROWDSHIELD_CONFIG=/config/crowdshield.yaml

# Optional ntfy settings. Supply real values only in the ignored local .env.
CROWDSHIELD_NOTIFICATIONS_ENABLED=false
CROWDSHIELD_NOTIFICATIONS_SERVER_URL=
CROWDSHIELD_NOTIFICATIONS_TOPIC=
CROWDSHIELD_NOTIFICATIONS_COOLDOWN=1h
CROWDSHIELD_NOTIFICATIONS_TOKEN=

# Optional runtime identity when the container must match bind-mounted file IDs.
CROWDSHIELD_UID=1000
CROWDSHIELD_GID=1000
