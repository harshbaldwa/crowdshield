# Numeric identity used by Compose for the process and bind-mounted files.
# Keep these values numeric and make config, credentials, and data ownership
# match them. The image default is the distroless nonroot identity 65532:65532.
CROWDSHIELD_UID=65532
CROWDSHIELD_GID=65532

# Reproducible image metadata. Release/commit builds should replace these with
# reviewed values; they are build arguments and are not passed to the container.
CROWDSHIELD_VERSION=dev
CROWDSHIELD_REVISION=unknown
CROWDSHIELD_BUILD_DATE=1970-01-01T00:00:00Z
SOURCE_DATE_EPOCH=0
